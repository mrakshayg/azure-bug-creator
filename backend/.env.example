PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://127.0.0.1:5173
SESSION_SECRET=replace-me

# Database: Supabase Postgres.
# Supabase → Project Settings → Database → Connection string → URI → Direct (port 5432).
# Append ?sslmode=require if the driver needs it.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

UPLOAD_DIR=./storage/uploads
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/tech4jc
AZURE_DEVOPS_PROJECT=00021-FYNXT Cloud
AZURE_DEVOPS_API_VERSION=7.1

# Optional emergency PAT fallback if no per-user token is stored.
# AZURE_DEVOPS_PAT=
